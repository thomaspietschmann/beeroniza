# ─────────────────────────────────────────────────────────────────────────
# Beeroniza configuration
#
# The ONLY hard requirement is a PostgreSQL connection. Postgres stores the
# application data, the job queue (pg-boss) AND generated files (by default),
# so a single DATABASE_URL is enough to run the whole thing.
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. REQUIRED.
# On Coolify: set this to your managed/attached Postgres service URL.
DATABASE_URL="postgresql://beeroniza:beeroniza@localhost:5432/beeroniza?schema=public"

# Secret used to sign auth sessions. REQUIRED in production.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-0000000000000000"

# Public base URL of the app (used for callback URLs and webhook examples).
# On Coolify this is your service domain, e.g. https://banners.example.com
APP_URL="http://localhost:3000"

# Trust the reverse proxy in front of the app (Coolify, Traefik, nginx...).
# Required so auth callbacks work behind a proxy. Keep "true" on Coolify.
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────

# Run the in-process render worker inside the web container.
# Default: true. Set to "false" only if you run dedicated worker containers
# (npm run worker) and want the web app to do nothing but serve HTTP.
RUN_WORKER="true"

# How many render jobs the worker processes concurrently.
WORKER_CONCURRENCY="2"

# File storage backend for uploads & generated images.
#   "db"    -> store bytes in Postgres (default, zero extra infrastructure)
#   "local" -> store on disk at STORAGE_LOCAL_PATH (needs a persistent volume)
STORAGE_DRIVER="db"
STORAGE_LOCAL_PATH="/app/storage"

# Allow public sign-ups. Set to "false" to lock down an instance after you
# created your account(s).
ALLOW_REGISTRATION="false"

# Port the Node server listens on. Coolify injects PORT automatically.
PORT="3000"

# ─────────────────────────────────────────────────────────────────────────
# OIDC / SSO (optional)
#
# Enable a generic OpenID Connect provider (Keycloak, Authentik, Zitadel, …).
# All three vars must be set to activate the SSO button on the login page.
# Register this redirect URI in your IdP:  {APP_URL}/api/auth/callback/oidc
# ─────────────────────────────────────────────────────────────────────────

# OIDC_ISSUER="https://keycloak.example.com/realms/myrealm"
# OIDC_CLIENT_ID="beeroniza"
# OIDC_CLIENT_SECRET="your-client-secret"
# OIDC_NAME="SSO"   # Label shown on the login button (default: SSO)

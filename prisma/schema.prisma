// Beeroniza data model.
//
// PostgreSQL is the single source of truth: application data lives here, the
// job queue (pg-boss) creates its own schema in the same database, and — with
// the default storage driver — uploaded and generated files are stored here too
// (StoredFile.data). One DATABASE_URL runs the whole system.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum FileKind {
  UPLOAD
  GENERATED
  FONT
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates   Template[]
  apiKeys     ApiKey[]
  generations ImageGeneration[]
  fonts       Font[]
  files       StoredFile[]
  usages      Usage[]
  brandKits   BrandKit[]

  @@map("users")
}

// Per-user brand kits: a user can have multiple named kits, each with named
// colour palettes. Exactly one kit per user is marked isDefault = true.
// palettes: [{ id, name, colors: string[] }]
model BrandKit {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Brand Kit")
  isDefault Boolean  @default(false)
  palettes  Json     @default("[]")
  fonts     String[] @default([])
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages Usage[]

  @@index([userId])
  @@map("brand_kits")
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  // Organisation for the templates listing: social platform group (e.g.
  // "Instagram") and a human format label (e.g. "Square 1080×1080"). Null
  // platform = a user's own/custom template ("Individuell").
  platform    String?
  formatLabel String?
  // Canvas dimensions in pixels.
  width       Int
  height      Int
  // Current (draft) template document — Fabric canvas JSON plus our
  // placeholder metadata. See src/lib/template/schema.ts.
  data        Json
  // Monotonically increasing published version counter.
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    TemplateVersion[]
  generations ImageGeneration[]
  usages      Usage[]

  @@index([userId])
  @@map("templates")
}

// A saved "usage" of a template: a named set of input VALUES (keyed by
// placeholder key) — text, an uploaded image (fileId), or a color. It stores
// inputs, NOT a baked image, so it always re-renders against the *current*
// template (layout/format/placeholder changes propagate automatically).
model Usage {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  name       String
  // { [placeholderKey]: { text?: string, fileId?: string, color?: string } }
  values     Json     @default("{}")
  // Which brand kit's colour palettes to show in the fill-in form.
  brandKitId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  brandKit    BrandKit?         @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  generations ImageGeneration[]

  @@index([templateId])
  @@index([userId])
  @@map("usages")
}

// Immutable snapshots so the API can pin a specific template_version while the
// owner keeps editing the draft.
model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  data       Json
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("template_versions")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  // First few characters shown in the UI to identify the key (e.g. "bnz_a1b2").
  prefix     String
  // SHA-256 hash of the full key. The plaintext key is shown exactly once.
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  // Optional expiration. When set and in the past, the key is rejected.
  expiresAt  DateTime?
  // Bumped each time the key is rotated (new secret issued for the same record).
  rotatedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model ImageGeneration {
  id              String           @id @default(cuid())
  userId          String
  templateId      String
  // Set when the generation was triggered from a saved usage, so the UI can
  // link a result back to the filled-in template. Null for ad-hoc/API renders.
  usageId         String?
  templateVersion Int?
  status          GenerationStatus @default(QUEUED)
  // The per-generation overrides keyed by placeholder/layer name.
  modifications   Json
  format          String           @default("png")
  width           Int
  height          Int
  // Result file (null until completed).
  fileId          String?
  error           String?
  // Optional webhook called when the job finishes.
  webhookUrl      String?
  // pg-boss job id for correlation.
  jobId           String?
  createdAt       DateTime         @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  usage    Usage?     @relation(fields: [usageId], references: [id], onDelete: SetNull)
  file     StoredFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@map("image_generations")
}

// Binary blobs. With STORAGE_DRIVER=db the bytes live in `data`. With
// STORAGE_DRIVER=local, `data` is null and `storageKey` points at a file on a
// mounted volume.
model StoredFile {
  id         String   @id @default(cuid())
  userId     String?
  kind       FileKind
  mimeType   String
  byteSize   Int
  width      Int?
  height     Int?
  data       Bytes?
  storageKey String?
  // Original filename at upload time; shown (and editable) in the media library.
  originalName String?
  // sha256 of the bytes, used to deduplicate uploads per user+kind.
  sha256       String?
  // Normalized face focal point (0..1) detected at upload; used by "face
  // gravity" cover-cropping. hasFace records whether a face was actually found.
  focalX     Float?
  focalY     Float?
  hasFace    Boolean  @default(false)
  createdAt  DateTime @default(now())

  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fonts       Font[]
  generations ImageGeneration[]

  @@index([userId])
  @@index([kind])
  @@index([userId, kind, sha256])
  @@map("stored_files")
}

// Fonts available for rendering. Bundled open-source fonts are seeded with
// userId = null and isBundled = true. Users can upload their own per-instance.
model Font {
  id        String   @id @default(cuid())
  userId    String?
  family    String
  weight    Int      @default(400)
  style     String   @default("normal")
  // woff2 / ttf / otf
  format    String
  fileId    String?
  isBundled Boolean  @default(false)
  // How the font got here: "bundled" (seeded open-source), "upload" (user file
  // upload), or "google" (imported & downloaded from Google Fonts). Drives the
  // overview grouping and which fonts the user may delete.
  source    String   @default("upload")
  createdAt DateTime @default(now())

  user User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  file StoredFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([family])
  @@map("fonts")
}
